# API Configuration
PORT=8000
HOST=127.0.0.1
ENVIRONMENT=development

# Security / CORS
# Comma-separated list of allowed origins. DO NOT use wildcard '*' in production.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database configuration
DATABASE_URL=sqlite:///./local_db.db

# Vector Database (ChromaDB)
CHROMA_PERSIST_DIR=./chroma_db

# OpenAI API Settings
OPENAI_API_KEY=your_openai_api_key_here

# Firebase Authentication (for token verification on the backend)
FIREBASE_PROJECT_ID=your_firebase_project_id_here

# LLM Provider Configuration ('openai' | 'claude' | 'ollama')
# For local dev without cost, set LLM_PROVIDER=ollama (requires Ollama running locally)
LLM_PROVIDER=openai
OLLAMA_API_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

