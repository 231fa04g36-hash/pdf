# Dockerfile for FastAPI RAG backend (Tesseract OCR & language packs installation)
FROM python:3.11-slim

# Install system dependencies (including Tesseract OCR and specific language packs)
# Note: Additional language packs (e.g. tesseract-ocr-ita, tesseract-ocr-por) can be added below if needed.
RUN apt-get update && apt-get install -y \
    build-essential \
    libpq-dev \
    poppler-utils \
    tesseract-ocr \
    tesseract-ocr-eng \
    tesseract-ocr-hin \
    tesseract-ocr-spa \
    tesseract-ocr-fra \
    tesseract-ocr-deu \
    && rm -rf /var/lib/apt/lists/*

# Set working directory
WORKDIR /app

# Copy requirements and install
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy application code
COPY . .

# Expose port and run
EXPOSE 8000
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
